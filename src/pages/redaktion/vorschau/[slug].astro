---
import { getCollection, render, type CollectionEntry } from "astro:content";
import AdSlot from "../../../components/AdSlot.astro";
import ArticleContentBlocks from "../../../components/ArticleContentBlocks.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  if (process.env.VERCEL_ENV !== "preview") return [];
  const drafts = await getCollection("drafts");
  return drafts.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"drafts"> };
const { Content } = await render(entry);
const data = entry.data;
const formattedDate = data.createdAt.toLocaleDateString("de-DE", {
  day: "2-digit",
  month: "long",
  year: "numeric"
});
const blockText = data.contentBlocks?.flatMap((block) => {
  if (block.type === "paragraph" || block.type === "heading") return [block.text];
  if (block.type === "list") return block.items;
  return [];
}).join(" ") ?? "";
const readingMinutes = Math.max(1, Math.ceil((blockText || entry.body || "").trim().split(/\s+/).filter(Boolean).length / 220));
const sourceLabel = (source: string) => {
  const host = new URL(source).hostname.replace(/^www\./, "");
  if (host.includes("steampowered.com")) {
    return source.includes("/news/") ? "Offizielle Steam-News" : "Offizielle Steam-Store-Seite";
  }
  if (data.secondarySources.includes(source)) return `Sekundaerquelle: ${host}`;
  return `Offizielle Quelle: ${host}`;
};
---

<BaseLayout
  title={`ENTWURF: ${data.seoTitle}`}
  description={data.seoDescription}
  image={data.heroImage}
  type="article"
  robots="noindex, nofollow"
>
  <div class="draft-preview-banner" role="status">ENTWURF · NICHT VERÖFFENTLICHT</div>
  {data.status === "secondary-source-review" ? (
    <div class="draft-preview-banner draft-preview-banner--warning" role="alert">
      Keine erreichbare Primaerquelle - Sekundaerquellen-Review - manuelle Pruefung zwingend
    </div>
  ) : null}
  <header class="article-header container">
    <nav class="breadcrumbs" aria-label="Brotkrumen">
      <a href="/redaktion/">Redaktion</a><span>/</span><span>Vorschau</span>
    </nav>
    <span class="badge">Redaktionelle Vorschau</span>
    <h1>{data.title}</h1>
    <p class="article-deck">{data.summary}</p>
    <div class="meta article-meta">
      <time datetime={data.createdAt.toISOString()}>{formattedDate}</time>
      <span>Â·</span><span>{data.author}</span>
      <span>Â·</span><span>{readingMinutes} Min. Lesezeit</span>
    </div>
  </header>

  <figure class="container article-hero-image">
    <img
      src={data.heroImage}
      data-fallback-src="/images/categories/news-default.svg"
      alt={data.heroImageAlt}
      width="1200"
      height="675"
    />
    <figcaption>
      Bildquelle: {data.heroImageSourceName}
      {data.heroImageCandidateStatus === "pending-review"
        ? " · offizieller Bildkandidat wartet auf manuelle Freigabe"
        : ""}
    </figcaption>
  </figure>

  <div class="container article-layout">
    <article class="article-main">
      <div class="article-body">
        {data.contentBlocks?.length
          ? <ArticleContentBlocks blocks={data.contentBlocks} />
          : <><Content /><div class="article-inline-ad"><AdSlot placement="article-inline-1" /></div></>}
      </div>
      <section class="sources-box">
        <p class="eyebrow">Quellen</p>
        {data.status === "secondary-source-review" ? (
          <p>Dieser Draft nutzt Sekundaerquellen und behauptet keine offizielle Bestaetigung.</p>
        ) : null}
        <ul>
          {[...data.primarySources, ...data.secondarySources].map((source) => (
            <li>
              <a class="text-link" href={source} target="_blank" rel="noopener noreferrer">
                {sourceLabel(source)}
              </a>
            </li>
          ))}
        </ul>
      </section>
      <section class="editorial-internal-panel">
        <p class="eyebrow">Interne Pruefung</p>
        <dl>
          <div><dt>Status</dt><dd>{data.status}</dd></div>
          <div><dt>Artikeltyp</dt><dd>{data.articleType}</dd></div>
          <div><dt>Tags</dt><dd>{data.tags.join(", ") || "keine"}</dd></div>
          <div><dt>Bildstatus</dt><dd>{data.imageRightsStatus}{data.heroImageCandidateStatus ? ` / ${data.heroImageCandidateStatus}` : ""}</dd></div>
          <div><dt>SEO-Titel</dt><dd>{data.seoTitle}</dd></div>
          <div><dt>SEO-Beschreibung</dt><dd>{data.seoDescription}</dd></div>
        </dl>
        {data.status === "secondary-source-review" ? (
          <>
            <h2>Sekundaerquellen-Pruefung</h2>
            <ul>
              <li>Keine erreichbare Primaerquelle.</li>
              <li>Verwendete Sekundaerquellen: {data.secondarySources.join(", ") || "keine"}</li>
              <li>Bestaetigte Kernfakten: {data.secondarySourceFacts.filter((fact) => fact.corroborated && !fact.contradicted).map((fact) => fact.statement).join(" / ") || "keine"}</li>
              <li>Unbestaetigte Angaben: {data.secondarySourceFacts.filter((fact) => !fact.corroborated || fact.isRumor).map((fact) => fact.statement).join(" / ") || "keine"}</li>
              <li>Widersprueche: {data.secondarySourceWarnings.filter((warning) => /widerspruch/i.test(warning)).join(" / ") || "keine"}</li>
              <li>Manuelle Pruefung zwingend; keine automatische Freigabe.</li>
            </ul>
          </>
        ) : null}
        {data.editorialNotes?.length ? (
          <>
            <h2>Interne Hinweise</h2>
            <ul>{data.editorialNotes.map((note) => <li>{note}</li>)}</ul>
          </>
        ) : null}
      </section>
    </article>
  </div>
</BaseLayout>

<script>
  const hero = document.querySelector<HTMLImageElement>(".article-hero-image img[data-fallback-src]");
  hero?.addEventListener("error", () => {
    hero.src = hero.dataset.fallbackSrc ?? "/images/categories/news-default.svg";
  }, { once: true });
</script>

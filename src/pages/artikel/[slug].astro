---
import { getCollection, render, type CollectionEntry } from "astro:content";
import AdSlot from "../../components/AdSlot.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import ArticleLayout from "../../components/ArticleLayout.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("articles", ({ data }) => data.status === "published");
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"articles"> };
const { Content } = await render(entry);
const data = entry.data;
const publishedArticles = await getCollection("articles", ({ data: candidate }) =>
  candidate.status === "published" && candidate.slug !== data.slug
);
const related = publishedArticles
  .filter((candidate) => candidate.data.tags.some((tag) => data.tags.includes(tag)))
  .slice(0, 2);
const formattedDate = data.createdAt.toLocaleDateString("de-DE", {
  day: "2-digit",
  month: "long",
  year: "numeric"
});
const articleUrl = new URL(Astro.url.pathname, Astro.site).toString();
const steamUrl = data.steamAppId
  ? `https://store.steampowered.com/app/${data.steamAppId}/`
  : undefined;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline: data.title,
  description: data.summary,
  image: new URL(data.heroImage, Astro.site).toString(),
  datePublished: data.createdAt.toISOString(),
  dateModified: data.updatedAt.toISOString(),
  author: { "@type": "Organization", name: data.author },
  publisher: { "@type": "Organization", name: "SpielSignal", url: "https://spielsignal.de" },
  mainEntityOfPage: articleUrl,
  inLanguage: "de-DE"
};
---

<BaseLayout
  title={data.seoTitle}
  description={data.seoDescription}
  image={data.heroImage}
  type="article"
  jsonLd={jsonLd}
>
  <header class="page-hero page-hero--compact container">
    <nav class="breadcrumbs" aria-label="Brotkrumen">
      <a href="/">Startseite</a><span>/</span><a href="/artikel/">Artikel</a><span>/</span><span>{data.title}</span>
    </nav>
    <span class="badge">{data.articleType}</span>
    <h1>{data.title}</h1>
    <p>{data.summary}</p>
    <div class="meta article-meta">
      <time datetime={data.createdAt.toISOString()}>{formattedDate}</time>
      <span>{data.author}</span>
      {data.gameTitle ? <span>{data.gameTitle}</span> : null}
    </div>
  </header>

  <div class="container article-hero-image">
    <img
      src={data.heroImage}
      data-fallback-src="/images/categories/news-default.svg"
      alt={`Titelbild zu ${data.title}`}
      width="1200"
      height="675"
    />
  </div>

  <ArticleLayout>
    <article>
      <div class="article-body"><Content /></div>
      <div class="article-ad"><AdSlot format="article" /></div>

      {steamUrl ? (
        <p><a class="button secondary" href={steamUrl} target="_blank" rel="noopener noreferrer">Offizielle Steam-Seite öffnen</a></p>
      ) : null}

      <section class="info-box sources-box">
        <h2>Quellen</h2>
        <ul>
          {data.primarySources.map((source) => (
            <li><a class="text-link" href={source} target="_blank" rel="noopener noreferrer">{new URL(source).hostname}</a></li>
          ))}
        </ul>
      </section>

      <div class="share" aria-label="Artikel teilen">
        <a href={`mailto:?subject=${encodeURIComponent(data.title)}&body=${encodeURIComponent(articleUrl)}`}>Per E-Mail teilen</a>
        <button class="filter copy-link" type="button" data-url={articleUrl}>Link kopieren</button>
      </div>

      {related.length ? (
        <section class="related-articles">
          <h2>Weitere passende Artikel</h2>
          <div class="grid">{related.map((candidate) => <ArticleCard entry={candidate} />)}</div>
        </section>
      ) : null}
      <div class="article-ad"><AdSlot format="article" /></div>
    </article>
    <aside><AdSlot format="sidebar" /></aside>
  </ArticleLayout>
</BaseLayout>

<script>
  const hero = document.querySelector<HTMLImageElement>(".article-hero-image img[data-fallback-src]");
  hero?.addEventListener("error", () => {
    hero.src = hero.dataset.fallbackSrc ?? "/images/categories/news-default.svg";
  }, { once: true });
  document.querySelector(".copy-link")?.addEventListener("click", async (event) => {
    const button = event.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(button.dataset.url ?? location.href);
    button.textContent = "Kopiert";
  });
</script>

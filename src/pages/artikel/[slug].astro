---
import { getCollection, render, type CollectionEntry } from "astro:content";
import AdSlot from "../../components/AdSlot.astro";
import NewsListItem from "../../components/NewsListItem.astro";
import SteamTrendsSidebar from "../../components/SteamTrendsSidebar.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSteamTrends } from "../../lib/steamData";

export async function getStaticPaths() {
  const entries = await getCollection("articles", ({ data }) => data.status === "published");
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"articles"> };
const { Content } = await render(entry);
const data = entry.data;
const publishedArticles = (await getCollection("articles", ({ data: candidate }) =>
  candidate.status === "published" && candidate.slug !== data.slug
)).sort((left, right) => right.data.createdAt.valueOf() - left.data.createdAt.valueOf());
const related = publishedArticles
  .filter((candidate) => candidate.data.tags.some((tag) => data.tags.includes(tag)))
  .slice(0, 3);
const moreNews = (related.length ? related : publishedArticles).slice(0, 3);
const steamTrends = await getSteamTrends();
const formattedDate = data.createdAt.toLocaleDateString("de-DE", {
  day: "2-digit",
  month: "long",
  year: "numeric"
});
const readingMinutes = Math.max(1, Math.ceil((entry.body?.trim().split(/\s+/).length ?? 0) / 220));
const articleUrl = new URL(Astro.url.pathname, Astro.site).toString();
const imageCredit = data.steamAppId === "1297900"
  ? "Bildquelle: Steam / THQ Nordic"
  : `Bildquelle: ${data.heroImageSourceType === "steam-store" ? "Steam" : "offizielle Quelle"}`;
const sourceLabel = (source: string) => {
  const host = new URL(source).hostname.replace(/^www\./, "");
  if (host.includes("steampowered.com")) return "Steam";
  if (host.includes("thqnordic.com")) return "THQ Nordic";
  return `Offizielle Quelle: ${host}`;
};
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline: data.title,
  description: data.summary,
  image: new URL(data.heroImage, Astro.site).toString(),
  datePublished: data.createdAt.toISOString(),
  dateModified: data.updatedAt.toISOString(),
  author: { "@type": "Organization", name: data.author },
  publisher: { "@type": "Organization", name: "SpielSignal", url: "https://spielsignal.de" },
  mainEntityOfPage: articleUrl,
  inLanguage: "de-DE"
};
---

<BaseLayout title={data.seoTitle} description={data.seoDescription} image={data.heroImage} type="article" jsonLd={jsonLd}>
  <header class="article-header container">
    <nav class="breadcrumbs" aria-label="Brotkrumen">
      <a href="/">Startseite</a><span>/</span><a href="/news/">News</a><span>/</span><span>{data.title}</span>
    </nav>
    <span class="badge">SpielSignal-News</span>
    <h1>{data.title}</h1>
    <p class="article-deck">{data.summary}</p>
    <div class="meta article-meta">
      <time datetime={data.createdAt.toISOString()}>{formattedDate}</time>
      <span>·</span><span>{data.author}</span>
      <span>·</span><span>{readingMinutes} Min. Lesezeit</span>
    </div>
  </header>

  <figure class="container article-hero-image">
    <img
      src={data.heroImage}
      data-fallback-src="/images/categories/news-default.svg"
      alt={`Titelbild zu ${data.title}`}
      width="1200"
      height="675"
    />
    <figcaption>{imageCredit}</figcaption>
  </figure>

  <div class="container article-layout">
    <article class="article-main">
      <div class="article-body"><Content /></div>
      <div class="article-inline-ad"><AdSlot format="article" /></div>

      <section class="sources-box">
        <p class="eyebrow">Quellen</p>
        <ul>
          {data.primarySources.map((source) => (
            <li>
              <a class="text-link" href={source} target="_blank" rel="noopener noreferrer">
                {sourceLabel(source)}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <div class="share" aria-label="Artikel teilen">
        <a href={`mailto:?subject=${encodeURIComponent(data.title)}&body=${encodeURIComponent(articleUrl)}`}>Per E-Mail teilen</a>
        <button class="filter copy-link" type="button" data-url={articleUrl}>Link kopieren</button>
      </div>
      <div class="article-ad"><AdSlot format="article" /></div>
    </article>

    <aside class="article-sidebar">
      <section class="sidebar-panel">
        <h2 class="sidebar-title"><span></span>Weitere News</h2>
        {moreNews.length ? (
          <div class="article-sidebar-news">
            {moreNews.map((candidate) => (
              <a href={`/artikel/${candidate.data.slug}/`}>{candidate.data.title}</a>
            ))}
          </div>
        ) : <p class="muted">Weitere eigene News sind in Vorbereitung.</p>}
      </section>
      <SteamTrendsSidebar items={steamTrends} />
      <AdSlot format="sidebar" />
    </aside>
  </div>

  <section class="section section--compact container">
    <p class="eyebrow">Aus der Redaktion</p>
    <h2 class="content-heading">Weitere News</h2>
    {moreNews.length ? <div class="news-list">{moreNews.map((candidate) => <NewsListItem entry={candidate} />)}</div> : (
      <div class="empty-editorial-state"><p>Weitere eigene SpielSignal-News sind in Vorbereitung.</p></div>
    )}
  </section>
</BaseLayout>

<script>
  const hero = document.querySelector<HTMLImageElement>(".article-hero-image img[data-fallback-src]");
  hero?.addEventListener("error", () => {
    hero.src = hero.dataset.fallbackSrc ?? "/images/categories/news-default.svg";
  }, { once: true });
  document.querySelector(".copy-link")?.addEventListener("click", async (event) => {
    const button = event.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(button.dataset.url ?? location.href);
    button.textContent = "Kopiert";
  });
</script>

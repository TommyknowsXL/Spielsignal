---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdSlot from "../../components/AdSlot.astro";
import AffiliateNotice from "../../components/AffiliateNotice.astro";
import ArticleLayout from "../../components/ArticleLayout.astro";

type AnyEntry =
  | CollectionEntry<"tests">
  | CollectionEntry<"recommendations">
  | CollectionEntry<"news">
  | CollectionEntry<"deals">
  | CollectionEntry<"releases">;

export async function getStaticPaths() {
  const entries = [
    ...(await getCollection("tests")),
    ...(await getCollection("recommendations")),
    ...(await getCollection("news")),
    ...(await getCollection("deals")),
    ...(await getCollection("releases"))
  ] as AnyEntry[];

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data as AnyEntry["data"] & {
  articleType?: string;
  strengths?: string[];
  weaknesses?: string[];
  verdict?: string;
  sources?: { name: string; url: string }[];
  sourceName?: string;
  sourceUrl?: string;
  affiliate?: boolean;
};
const articleType = data.articleType ?? "Artikel";
const formattedDate = data.date.toLocaleDateString("de-DE", {
  day: "2-digit",
  month: "long",
  year: "numeric"
});
const articleUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: data.title,
  description: data.description,
  datePublished: data.date.toISOString(),
  author: { "@type": "Organization", name: data.author },
  publisher: { "@type": "Organization", name: "SpielSignal", url: "https://spielsignal.de" },
  mainEntityOfPage: articleUrl,
  inLanguage: "de-DE"
};
---

<BaseLayout
  title={data.seoTitle}
  description={data.seoDescription}
  type="article"
  jsonLd={jsonLd}
>
  <header class="page-hero container">
    <nav class="breadcrumbs" aria-label="Brotkrumen">
      <a href="/">Startseite</a><span>/</span><a href="/tests/">Artikel</a><span>/</span><span>{data.title}</span>
    </nav>
    <span class="badge">{articleType}</span>
    <h1 style="margin-top: 1rem;">{data.title}</h1>
    <p>{data.description}</p>
    <div class="meta" style="margin-top: 1.2rem;">
      <span>{formattedDate}</span><span>{data.author}</span><span>{data.category}</span>
    </div>
    {data.demo && <p class="demo-note" style="margin-top: 1rem;">DEMO-INHALT – keine reale Bewertung oder aktuelle Meldung</p>}
  </header>

  <ArticleLayout>
    <article>
      <div class="article-body"><Content /></div>

      <div style="margin-block: 2rem;"><AdSlot format="article" /></div>

      {
        data.strengths && data.weaknesses && (
          <div class="pros-cons">
            <section class="info-box">
              <h3>Stärken</h3>
              <ul>{data.strengths.map((item) => <li>{item}</li>)}</ul>
            </section>
            <section class="info-box">
              <h3>Schwächen</h3>
              <ul>{data.weaknesses.map((item) => <li>{item}</li>)}</ul>
            </section>
          </div>
        )
      }

      {data.verdict && <section class="info-box"><h2>Fazit</h2><p>{data.verdict}</p></section>}

      {
        entry.collection === "deals" && (
          <div style="margin-top: 1rem;"><AffiliateNotice /></div>
        )
      }

      <div class="share" aria-label="Artikel teilen">
        <a href={`mailto:?subject=${encodeURIComponent(data.title)}&body=${encodeURIComponent(articleUrl)}`}>Per E-Mail teilen</a>
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(articleUrl)}`} rel="noopener" target="_blank">LinkedIn</a>
        <button class="filter copy-link" type="button" data-url={articleUrl}>Link kopieren</button>
      </div>

      <section class="info-box">
        <h3>Quellen</h3>
        {
          data.sources?.length ? (
            <ul>{data.sources.map((source) => <li><a class="text-link" href={source.url}>{source.name}</a></li>)}</ul>
          ) : data.sourceUrl ? (
            <p><a class="text-link" href={data.sourceUrl}>Originalquelle: {data.sourceName}</a></p>
          ) : (
            <p class="muted">Für diesen eigenen Demo-Beitrag wurden keine externen Quellen verwendet.</p>
          )
        }
      </section>

      <section class="author-box" style="margin-top: 1rem;">
        <h3>SpielSignal Redaktion</h3>
        <p class="muted">Ordnet PC-Gaming-Themen knapp ein und kennzeichnet Demo-Inhalte, Quellen und geschäftliche Beziehungen transparent.</p>
      </section>

      <div style="margin-top: 2rem;"><AdSlot format="article" /></div>
    </article>

    <aside>
      <AdSlot format="sidebar" />
      <section class="info-box" style="margin-top: 1rem;">
        <h3>Weitere Artikel</h3>
        <p class="muted" style="margin-top: .5rem;">Mehr Demo-Inhalte findest du in unseren Tests und Empfehlungen.</p>
        <a class="text-link" href="/tests/">Zu den Artikeln →</a>
      </section>
    </aside>
  </ArticleLayout>
</BaseLayout>

<script>
  document.querySelector(".copy-link")?.addEventListener("click", async (event) => {
    const button = event.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(button.dataset.url ?? location.href);
    button.textContent = "Kopiert";
  });
</script>

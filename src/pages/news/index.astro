---
import { getCollection } from "astro:content";
import AdSlot from "../../components/AdSlot.astro";
import ExternalNewsList from "../../components/ExternalNewsList.astro";
import NewsListItem from "../../components/NewsListItem.astro";
import SteamTrendsSidebar from "../../components/SteamTrendsSidebar.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAggregatedNews } from "../../lib/newsFeed";
import { prepareNewsItems } from "../../lib/newsPresentation";
import { getSteamTrends } from "../../lib/steamData";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
);

const articles = (await getCollection("articles", ({ data }) => data.status === "published"))
  .sort((left, right) => right.data.createdAt.valueOf() - left.data.createdAt.valueOf());
const feedResult = await getAggregatedNews();
const externalNews = await prepareNewsItems(feedResult.items, { limit: 5 });
const steamTrends = await getSteamTrends();
---

<BaseLayout
  title="News | SpielSignal"
  description="Eigene SpielSignal-News zu PC-Spielen, ergänzt durch kompakte externe Kurzmeldungen."
>
  <header class="page-hero page-hero--compact container">
    <nav class="breadcrumbs" aria-label="Brotkrumen">
      <a href="/">Startseite</a><span>/</span><span>News</span>
    </nav>
    <p class="eyebrow">SpielSignal-Redaktion</p>
    <h1>News</h1>
    <p>Eigenständige Beiträge auf Basis offizieller Quellen. Externe Meldungen bleiben ein klar gekennzeichneter Themenradar.</p>
  </header>

  <section class="section section--compact">
    <div class="container magazine-layout">
      <div class="magazine-main">
        <h2 class="content-heading">Aktuelle SpielSignal-News</h2>
        {articles.length ? (
          <div class="news-list">
            {articles.map((entry, index) => (
              <>
                <NewsListItem entry={entry} />
                {index === 3 ? <AdSlot format="feed" /> : null}
              </>
            ))}
          </div>
        ) : (
          <div class="empty-editorial-state">
            <strong>Weitere eigene SpielSignal-News sind in Vorbereitung.</strong>
            <p>Beiträge erscheinen erst nach redaktioneller Prüfung.</p>
          </div>
        )}
      </div>
      <aside class="magazine-sidebar">
        <ExternalNewsList items={externalNews} />
        <SteamTrendsSidebar items={steamTrends} />
        <AdSlot format="sidebar" />
      </aside>
    </div>
  </section>
</BaseLayout>

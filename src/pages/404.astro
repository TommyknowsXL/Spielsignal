---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Seite nicht gefunden | SpielSignal" description="Die angeforderte Seite wurde nicht gefunden.">
  <section class="hero">
    <div class="narrow hero-copy">
      <p class="eyebrow">Fehler 404</p>
      <h1>Dieses Signal ist abgerissen.</h1>
      <p class="lead">Die gesuchte Seite wurde verschoben, gelöscht oder war nie hier.</p>
      <div class="actions"><a class="button" href="/">Zur Startseite</a><a class="button secondary" href="/news/">News ansehen</a></div>
    </div>
  </section>
</BaseLayout>

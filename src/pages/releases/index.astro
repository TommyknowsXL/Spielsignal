---
import SteamReleaseGrid from "../../components/SteamReleaseGrid.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSteamReleases } from "../../lib/steamData";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
);

const releases = (await getSteamReleases()).slice(0, 30);
---

<BaseLayout
  title="Steam-Releases | SpielSignal"
  description="Neue PC-Spiele auf Steam aus geprüften offiziellen Store-Daten."
>
  <header class="page-hero page-hero--compact container">
    <nav class="breadcrumbs" aria-label="Brotkrumen">
      <a href="/">Startseite</a><span>/</span><span>Steam-Releases</span>
    </nav>
    <p class="eyebrow">Neue PC-Spiele</p>
    <h1>Steam-Releases</h1>
    <p>Eine kompakte Übersicht neuer PC-Veröffentlichungen. Angezeigt werden nur verlässlich geprüfte Steam-Daten.</p>
  </header>
  <section class="section section--compact container">
    <SteamReleaseGrid items={releases} />
  </section>
</BaseLayout>

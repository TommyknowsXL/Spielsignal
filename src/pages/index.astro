---
import { getCollection } from "astro:content";
import AdSlot from "../components/AdSlot.astro";
import ExternalNewsList from "../components/ExternalNewsList.astro";
import HeroNews from "../components/HeroNews.astro";
import NewsListItem from "../components/NewsListItem.astro";
import PcGamePassGrid from "../components/PcGamePassGrid.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SteamReleaseGrid from "../components/SteamReleaseGrid.astro";
import SteamTrendsSidebar from "../components/SteamTrendsSidebar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { approvedPcGamePassEntries } from "../data/pcGamePassEntries";
import { getAggregatedNews } from "../lib/newsFeed";
import { prepareNewsItems } from "../lib/newsPresentation";
import { getSteamReleases, getSteamTrends } from "../lib/steamData";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
);

const articles = (await getCollection("articles", ({ data }) => data.status === "published"))
  .sort((left, right) => right.data.createdAt.valueOf() - left.data.createdAt.valueOf())
  .slice(0, 8);
const feedResult = await getAggregatedNews();
const externalNews = await prepareNewsItems(feedResult.items, { limit: 5 });
const steamTrends = await getSteamTrends();
const releases = (await getSteamReleases()).slice(0, 6);
const newGamePass = approvedPcGamePassEntries.filter((entry) => entry.type === "new");
const leavingGamePass = approvedPcGamePassEntries.filter((entry) => entry.type === "leaving-soon");
---

<BaseLayout
  title="SpielSignal | PC-Gaming-News, Steam-Releases und PC Game Pass"
  description="Aktuelle PC-Gaming-News, neue Steam-Releases und neue PC-Game-Pass-Spiele auf einen Blick."
>
  <HeroNews articles={articles.slice(0, 5)} />
  <div class="container home-ad"><AdSlot format="wide" /></div>

  <section class="section section--compact">
    <div class="container magazine-layout">
      <div class="magazine-main">
        <SectionHeader eyebrow="Aus der Redaktion" title="Aktuelle SpielSignal-News" href="/news/" linkLabel="Alle News" />
        <div class="news-list">
          {articles.slice(0, 8).map((entry, index) => (
            <>
              <NewsListItem entry={entry} />
              {index === 2 ? <AdSlot format="feed" /> : null}
            </>
          ))}
        </div>
        {articles.length < 2 ? (
          <p class="editorial-note">Weitere eigene SpielSignal-News sind in Vorbereitung.</p>
        ) : null}
      </div>
      <aside class="magazine-sidebar">
        <ExternalNewsList items={externalNews} />
        <SteamTrendsSidebar items={steamTrends} />
        <AdSlot format="sidebar" />
      </aside>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <SectionHeader eyebrow="Offizielle Store-Daten" title="Neue Steam-Releases" href="/releases/" linkLabel="Zur Übersicht" />
      <SteamReleaseGrid items={releases} compact />
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <SectionHeader eyebrow="Offizielle Xbox-Quellen" title="Neu im PC Game Pass" href="/pc-game-pass/" linkLabel="Zur Übersicht" />
      <PcGamePassGrid entries={newGamePass} />
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <SectionHeader eyebrow="Rechtzeitig weiterspielen" title="Bald nicht mehr im PC Game Pass" href="/pc-game-pass/" linkLabel="Alle Einträge" />
      <PcGamePassGrid entries={leavingGamePass} />
    </div>
  </section>

  <div class="container home-ad home-ad--bottom"><AdSlot format="wide" /></div>
</BaseLayout>

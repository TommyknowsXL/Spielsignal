---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdSlot from "../components/AdSlot.astro";
import ExternalNewsCard from "../components/ExternalNewsCard.astro";
import Hero from "../components/Hero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SteamTrendsSidebar from "../components/SteamTrendsSidebar.astro";
import TrendingSidebar from "../components/TrendingSidebar.astro";
import { getAggregatedNews } from "../lib/newsFeed";
import { prepareNewsItems } from "../lib/newsPresentation";
import { getSteamTrends } from "../lib/steamData";
import { getTrendingItems } from "../lib/trending";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
);

const feedResult = await getAggregatedNews();
const preparedNews = await prepareNewsItems(feedResult.items, { limit: 24 });
const seenSteamApps = new Set<string>();
const topNews = preparedNews
  .filter((item) => {
    if (item.imageKind === "fallback" || !item.steamAppId) return false;
    if (seenSteamApps.has(item.steamAppId)) return false;
    seenSteamApps.add(item.steamAppId);
    return true;
  })
  .slice(0, 6);
const trendingResult = await getTrendingItems(preparedNews);
const steamTrends = await getSteamTrends();
---

<BaseLayout
  title="SpielSignal – Aktuelle PC-Gaming-News"
  description="Aktuelle PC-Gaming-News und offizielle Steam-Trends, kompakt und ohne Themenballast."
>
  <Hero />

  <section class="section section--compact" id="aktuelle-meldungen">
    <div class="container home-magazine">
      <div class="home-main">
        <SectionHeader eyebrow="Aktuell im PC-Gaming" title="Top-Meldungen" href="/news/" linkLabel="Alle News" />
        {
          topNews.length ? (
            <div class="grid news-grid">
              {topNews.map((item) => <ExternalNewsCard item={item} />)}
            </div>
          ) : (
            <div class="empty-editorial-state">
              <strong>Neue Meldungen werden gerade geprüft.</strong>
              <p>Hier erscheinen nur Gaming-News mit eindeutig zugeordnetem offiziellem Spielbild.</p>
              <a class="text-link" href="/news/">Alle geprüften Meldungen ansehen →</a>
            </div>
          )
        }
      </div>

      <aside class="home-sidebar">
        {trendingResult.items.length ? <TrendingSidebar result={trendingResult} /> : null}
        <SteamTrendsSidebar items={steamTrends} />
        <AdSlot format="sidebar" />
      </aside>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <SectionHeader eyebrow="Aus der Redaktion" title="Neueste Tests" href="/tests/" linkLabel="Zum Testbereich" />
      <div class="empty-editorial-state empty-editorial-state--inline">
        <strong>Die ersten SpielSignal-Tests sind in Vorbereitung.</strong>
        <p>Wir veröffentlichen Bewertungen erst, wenn Spiele gründlich geprüft wurden.</p>
      </div>
    </div>
  </section>

  <div class="container"><AdSlot format="wide" /></div>
</BaseLayout>

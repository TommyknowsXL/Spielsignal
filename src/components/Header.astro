---
import Logo from "./Logo.astro";

const path = Astro.url.pathname;
const links = [
  ["/news/", "News"],
  ["/releases/", "Steam-Releases"],
  ["/pc-game-pass/", "PC Game Pass"]
];
const isActive = (href: string) => path === href || path.startsWith(href);
---

<header class="site-header">
  <div class="container nav-wrap">
    <a class="brand" href="/" aria-label="SpielSignal Startseite"><Logo /></a>
    <nav class="desktop-nav" aria-label="Hauptnavigation">
      {links.map(([href, label]) => (
        <a href={href} aria-current={isActive(href) ? "page" : undefined}>{label}</a>
      ))}
    </nav>
    <div class="header-actions">
      <a class="search-button" href="/suche/" aria-label="Suche öffnen"><span aria-hidden="true">⌕</span><span>Suche</span></a>
      <button class="menu-button" type="button" aria-label="Menü öffnen" aria-expanded="false"><span aria-hidden="true">☰</span></button>
    </div>
  </div>
  <details class="mobile-nav container">
    <summary>Navigation</summary>
    <nav aria-label="Mobile Navigation">
      {links.map(([href, label]) => <a href={href} aria-current={isActive(href) ? "page" : undefined}>{label}</a>)}
    </nav>
  </details>
</header>

<script>
  const button = document.querySelector<HTMLButtonElement>(".menu-button");
  const menu = document.querySelector<HTMLDetailsElement>(".mobile-nav");
  button?.addEventListener("click", () => {
    if (!menu) return;
    menu.open = !menu.open;
    button.setAttribute("aria-expanded", String(menu.open));
  });
</script>

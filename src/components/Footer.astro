---
import Logo from "./Logo.astro";
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a class="brand" href="/"><Logo tagline={true} /></a>
        <p class="muted" style="margin-top: 1rem; max-width: 34rem;">
          Aktuelle PC-Gaming-News, neue Steam-Releases und neue PC-Game-Pass-Spiele auf einen Blick.
        </p>
      </div>
      <nav class="footer-links" aria-label="Inhalte">
        <strong>Inhalte</strong>
        <a href="/news/">News</a>
        <a href="/releases/">Steam-Releases</a>
        <a href="/pc-game-pass/">PC Game Pass</a>
        <a href="/rss.xml">RSS-Feed</a>
      </nav>
      <nav class="footer-links" aria-label="SpielSignal">
        <strong>SpielSignal</strong>
        <a href="/ueber-spielsignal/">Über SpielSignal</a>
        <a href="/kontakt/">Kontakt</a>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} SpielSignal</span>
      <span>Werbung und externe Quellen werden transparent gekennzeichnet.</span>
    </div>
  </div>
</footer>

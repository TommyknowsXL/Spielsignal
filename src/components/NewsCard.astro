---
interface Props {
  title: string;
  category: string;
  time: string;
  source: string;
  sourceUrl: string;
  note: string;
  image: string;
  imageAlt: string;
}
const { title, category, time, source, sourceUrl, note, image, imageAlt } = Astro.props;
---

<article class="card news-card" data-category={category}>
  <img class="card-image" src={image} alt={imageAlt} width="800" height="450" loading="lazy" />
  <div class="card-body">
    <span class:list={["badge", category === "Deals" && "badge--deal"]}>{category}</span>
    <h3>{title}</h3>
    <div class="meta"><span>{time}</span><span>Quelle: {source}</span></div>
    <p class="muted card-teaser">{note}</p>
    <p class="demo-note">Beispieldaten – keine aktuelle Meldung</p>
    <a class="text-link" href={sourceUrl} rel="nofollow noopener" target="_blank">
      Demo-Quelle öffnen ↗
    </a>
  </div>
</article>

---
interface Props {
  title: string; category: string; date: string; score: string; href: string; image: string;
}
const { title, category, date, score, href, image } = Astro.props;
---
<article class="card review-card">
  <a class="card-link" href={href}>
    <div class="card-image-wrap"><img class="card-image" src={image} alt={`Abstrakter Demo-Platzhalter zu ${title}`} width="800" height="450" loading="lazy" /><span class="image-label">TEST</span></div>
    <div class="card-body">
      <div class="card-top"><span class="badge">{category}</span><span class="score">{score}</span></div>
      <h3>{title}</h3>
      <p class="muted card-teaser">Ein klar gekennzeichneter Musterartikel für das künftige Testformat.</p>
      <div class="meta"><span>{date}</span><span>Demo-Inhalt</span></div>
      <span class="text-link">Test lesen →</span>
    </div>
  </a>
</article>

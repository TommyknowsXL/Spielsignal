---
interface Props {
  title: string; category: string; date: string; score: string; href: string;
}
const { title, category, date, score, href } = Astro.props;
---
<article class="card review-card">
  <div class="visual visual--review" aria-hidden="true"><span>TEST</span></div>
  <div class="card-body">
    <div class="card-top"><span class="badge">{category}</span><span class="score">{score}</span></div>
    <h3>{title}</h3>
    <p class="muted">Ein klar gekennzeichneter Musterartikel für das künftige Testformat.</p>
    <div class="meta"><span>{date}</span><span>Demo-Inhalt</span></div>
    <a class="text-link" href={href}>Test lesen →</a>
  </div>
</article>

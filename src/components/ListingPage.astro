---
import BaseLayout from "../layouts/BaseLayout.astro";
import { demoImageAlt, demoImageFor } from "../data/demoImages";

interface Item {
  title: string;
  description: string;
  category: string;
  href: string;
  label: string;
}

interface Props {
  title: string;
  eyebrow: string;
  description: string;
  items: Item[];
}

const { title, eyebrow, description, items } = Astro.props;
---

<BaseLayout title={`${title} | SpielSignal`} description={description}>
  <header class="page-hero container">
    <nav class="breadcrumbs" aria-label="Brotkrumen"><a href="/">Startseite</a><span>/</span><span>{title}</span></nav>
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p>{description}</p>
  </header>
  <section class="section container">
    <div class="grid grid-3">
      {items.map((item) => (
        <article class="card">
          <a class="card-link" href={item.href}>
            <img
              class="card-image"
              src={demoImageFor(item.category)}
              alt={demoImageAlt(item.category)}
              width="800"
              height="450"
              loading="lazy"
            />
            <div class="card-body">
              <span class="badge">{item.category}</span>
              <h3>{item.title}</h3>
              <p class="muted">{item.description}</p>
              <p class="demo-note">Demo-Inhalt</p>
              <span class="button secondary">{item.label}</span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

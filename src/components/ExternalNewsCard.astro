---
import type { PresentedNewsItem } from "../lib/newsPresentation";

interface Props {
  item: PresentedNewsItem;
}

const { item } = Astro.props;
const published = new Date(item.date).toLocaleString("de-DE", {
  dateStyle: "medium",
  timeStyle: "short",
  timeZone: "Europe/Berlin"
});
---

<article class="card news-card" data-category={item.category}>
  <a class="card-link" href={item.url} rel="noopener noreferrer" target="_blank">
    <img
      class="card-image"
      src={item.image}
      data-fallback-src={item.fallbackImage}
      alt={item.imageAlt}
      width="800"
      height="450"
      loading="lazy"
      data-image-kind={item.imageKind}
    />
    <div class="card-body">
      <span class="badge">{item.category}</span>
      <h3>{item.title}</h3>
      <div class="meta">
        <time datetime={item.date}>{published} Uhr</time>
        <span>Quelle: {item.sourceName}</span>
      </div>
      <span class="text-link">Originalmeldung lesen ↗</span>
    </div>
  </a>
</article>

<script>
  document.querySelectorAll<HTMLImageElement>(".news-card img[data-fallback-src]").forEach((image) => {
    image.addEventListener("error", () => {
      const fallback = image.dataset.fallbackSrc;
      if (fallback) image.src = fallback;
    }, { once: true });
  });
</script>

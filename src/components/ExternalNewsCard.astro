---
import type { AggregatedNewsItem } from "../lib/newsFeed";
import { demoImageAlt, demoImageFor } from "../data/demoImages";

interface Props {
  item: AggregatedNewsItem;
}

const { item } = Astro.props;
const published = new Date(item.date).toLocaleString("de-DE", {
  dateStyle: "medium",
  timeStyle: "short",
  timeZone: "Europe/Berlin"
});
---

<article class="card news-card" data-category={item.category}>
  <img class="card-image" src={demoImageFor(item.category)} alt={demoImageAlt(item.category)} width="800" height="450" loading="lazy" />
  <div class="card-body">
    <span class="badge">{item.category}</span>
    <h3>{item.title}</h3>
    <div class="meta">
      <time datetime={item.date}>{published} Uhr</time>
      <span>Externe Quelle: <a href={item.sourceHomepageUrl} rel="noopener noreferrer" target="_blank">{item.sourceName}</a></span>
    </div>
    {
      item.similarTo && (
        <p class="similar-note">Ähnliches Thema bereits im Feed: „{item.similarTo}“</p>
      )
    }
    <p class="muted card-teaser">
      Der vollständige Beitrag befindet sich auf der Webseite der Quelle.
    </p>
    <a class="button secondary" href={item.url} rel="noopener noreferrer" target="_blank">
      Originalmeldung lesen ↗
    </a>
  </div>
</article>

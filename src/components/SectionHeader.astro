---
interface Props { eyebrow?: string; title: string; href?: string; linkLabel?: string; }
const { eyebrow, title, href, linkLabel = "Alle ansehen" } = Astro.props;
---
<div class="section-head">
  <div>{eyebrow && <p class="eyebrow">{eyebrow}</p>}<h2>{title}</h2></div>
  {href && <a class="text-link" href={href}>{linkLabel} →</a>}
</div>

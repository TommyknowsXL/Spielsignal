---
interface Props { title: string; text: string; href: string; }
const { title, text, href } = Astro.props;
---
<article class="card recommendation-card">
  <div class="visual visual--recommendation" aria-hidden="true">?</div>
  <div class="card-body">
    <span class="badge">Demo-Empfehlung</span><h3>{title}</h3><p class="muted">{text}</p>
    <a class="text-link" href={href}>Beispiel lesen →</a>
  </div>
</article>

---
interface Props {
  variant?: "horizontal" | "stacked" | "icon";
  tone?: "light" | "dark";
  tagline?: boolean;
  class?: string;
}

const {
  variant = "horizontal",
  tone = "light",
  tagline = false,
  class: className
} = Astro.props;
const textColor = tone === "dark" ? "#0B1020" : "#F3F5F7";
---

<span class:list={["logo", `logo--${variant}`, className]} aria-label="SpielSignal">
  <svg class="logo__mark" viewBox="0 0 64 64" aria-hidden="true">
    <defs>
      <linearGradient id="signal-gradient" x1="10" y1="8" x2="54" y2="56" gradientUnits="userSpaceOnUse">
        <stop stop-color="#3CE6FF" />
        <stop offset="1" stop-color="#4F7CFF" />
      </linearGradient>
    </defs>
    <path d="M10 37a22 22 0 0 1 35-18" fill="none" stroke="url(#signal-gradient)" stroke-width="5" stroke-linecap="round"/>
    <path d="M17 42a16 16 0 0 1 24-18" fill="none" stroke="url(#signal-gradient)" stroke-width="5" stroke-linecap="round"/>
    <path d="M25 45a9 9 0 0 1 11-14" fill="none" stroke="url(#signal-gradient)" stroke-width="5" stroke-linecap="round"/>
    <path d="M36 35 51 20" fill="none" stroke={textColor} stroke-width="4" stroke-linecap="round"/>
    <circle cx="32" cy="39" r="5" fill={textColor}/>
    <path d="M46 29a22 22 0 0 1-2 24M52 35a28 28 0 0 1-3 21" fill="none" stroke="url(#signal-gradient)" stroke-width="4" stroke-linecap="round"/>
  </svg>
  {
    variant !== "icon" && (
      <span class="logo__copy">
        <span class="logo__wordmark" style={`color:${textColor}`}>SpielSignal</span>
        {tagline && <span class="logo__tagline">PC-Gaming-News, Tests und Deals auf einen Blick</span>}
      </span>
    )
  }
</span>

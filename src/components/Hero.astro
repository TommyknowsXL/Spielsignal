---
import PrimaryButton from "./PrimaryButton.astro";
import SecondaryButton from "./SecondaryButton.astro";
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">SpielSignal · PC-Gaming im Überblick</p>
      <h1>Alles Wichtige aus der PC-Gaming-Welt. <span>An einem Ort.</span></h1>
      <p class="lead">
        Aktuelle Meldungen, eigene Artikel und interessante Spiele, die einen Blick wert sind.
      </p>
      <div class="actions">
        <PrimaryButton href="#aktuelle-meldungen">Neueste News ansehen</PrimaryButton>
        <SecondaryButton href="/artikel/">Eigene Artikel entdecken</SecondaryButton>
      </div>
    </div>
    <div class="hero-art" aria-label="Abstrakte SpielSignal Gaming-Landschaft">
      <img
        src="/images/hero/spielsignal-gaming-hero.svg"
        alt="Futuristische, abstrakte PC-Gaming-Landschaft in den SpielSignal-Farben"
        width="1000"
        height="650"
      />
      <div class="featured-radar" aria-hidden="true"></div>
      <div class="hero-art__caption">
        <span class="badge">SpielSignal</span>
        <strong>News, Einordnung und Steam-Trends</strong>
      </div>
    </div>
  </div>
</section>

---
import PrimaryButton from "./PrimaryButton.astro";
import SecondaryButton from "./SecondaryButton.astro";
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">PC-Gaming. Klar auf den Punkt.</p>
      <h1>Dein Signal für gute <span>PC-Spiele.</span></h1>
      <p class="lead">
        Aktuelle Gaming-News, offizielle Steam-Trends und später ehrliche Tests:
        kompakt, nachvollziehbar und ohne Themenballast.
      </p>
      <div class="actions">
        <PrimaryButton href="#aktuelle-meldungen">Gaming-News entdecken</PrimaryButton>
        <SecondaryButton href="/news/">Alle Meldungen</SecondaryButton>
      </div>
    </div>
    <div class="hero-art" aria-label="Abstrakte SpielSignal Gaming-Landschaft">
      <img
        src="/images/hero/spielsignal-gaming-hero.svg"
        alt="Futuristische, abstrakte PC-Gaming-Landschaft in den SpielSignal-Farben"
        width="1000"
        height="650"
      />
      <div class="featured-radar" aria-hidden="true"></div>
      <div class="hero-art__caption">
        <span class="badge">SpielSignal</span>
        <strong>PC-Gaming-News ohne Umwege</strong>
      </div>
    </div>
  </div>
</section>
